{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git pull origin main",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Sincronizando com main..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git add -A; git diff --staged --quiet; if ($LASTEXITCODE -ne 0) { git commit -m 'auto-sync' }; git push",
            "shell": "powershell",
            "timeout": 60,
            "statusMessage": "Fazendo push automático..."
          }
        ]
      }
    ]
  }
}
